datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}


enum Role {
  DOCTOR
  PATIENT
  ADMIN
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String
  role          String    @default("PATIENT")
  
  accounts      Account[]
  sessions      Session[]
  
  doctorProfile DoctorProfile?

  appointments        Appointment[] @relation("PatientToAppointment")
  doctorAppointments  Appointment[] @relation("DoctorToAppointment")
}

model DoctorProfile {
  id         String  @id @default(cuid())
  specialty  String?
  bio        String?
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Appointment {
  id        String            @id   @default(cuid())
  date      DateTime
  status    AppointmentStatus @default(CONFIRMED)

  doctorId  String
  doctor    User              @relation("DoctorToAppointment", fields: [doctorId], references: [id])

  patientId String
  patient   User              @relation("PatientToAppointment", fields: [patientId], references: [id])

  @@unique([doctorId, date])
  
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

enum AppointmentStatus {
  CONFIRMED
  CANCELLED
  PENDING
  COMPLETED
}